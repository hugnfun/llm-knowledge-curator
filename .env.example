# --- LLM Knowledge Curator configuration ---
# Copy to .env and fill in your values.

# Vault path (Obsidian knowledge base)
LLKC_VAULT=~/Library/Mobile Documents/iCloud~md~obsidian/Documents/LLM知识库

# Project root (where this repo lives)
LLKC_PROJ=~/Documents/Project/llm-knowledge-curator

# Database path (relative to project root)
LLKC_DB=output/llkc.db

# --- LLM API (parser + writer) ---
# Used by the parser (content classification) and writer (draft generation)
LLM_API_BASE=https://ark.cn-beijing.volces.com/api/coding/v3
LLM_API_KEY=your-api-key-here
LLM_MODEL=ark-code-latest

# Writer-specific overrides (optional, defaults to LLM_* above)
# WRITER_API_KEY=
# WRITER_API_BASE=
# WRITER_MODEL=

# --- Pipeline settings ---
LLKC_PARSER_CONCURRENCY=5
LLKC_PARSER_TIMEOUT=90
LLKC_PARSER_MAX_INPUT_CHARS=12000
LLKC_WRITER_TIMEOUT=180
LLKC_WRITER_MAX_TOKENS=10000

# --- API server ---
LLKC_API_HOST=127.0.0.1
LLKC_API_PORT=8765

# --- Feishu bot URL capture ---
# lark-cli must be configured with a ready bot identity.
LLKC_LARK_CLI=lark-cli
# Optional comma-separated allowlists. Empty means accept every visible chat/sender.
# LLKC_LARK_CHAT_IDS=oc_xxx
# LLKC_LARK_SENDER_IDS=ou_xxx

# --- Pending URL cron connector ---
LLKC_PENDING_URL_LIMIT=20
LLKC_PENDING_URL_MAX_ATTEMPTS=3
LLKC_PENDING_URL_STALE_SECONDS=3600
