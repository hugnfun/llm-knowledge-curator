{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "CommonJS",
    "target": "ES2022",
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "node",
    "strictNullChecks": true,
    "lib": ["DOM", "ES5", "ES6", "ES7", "ES2020", "ES2022"]
  },
  "include": ["src/**/*.ts"]
}
